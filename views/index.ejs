<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Rating</title>
</head>
<body>
    <div class="container">
        <% let num = 1; %>
        <% data.forEach(d => { %>
            <div class="rating-container">
                <p><%= num++ %></p>
                <img src="<%= d.cover_image %>" alt="<%= d.title %> cover">
                <h1><%= d.title %></h1>
                <h2>Author: <%= d.author_name%></h2>
                <p><%= d.review %></p>
                <h3>Rate: <%= d.stars %>/5</h3>
                <div class="action-buttons">
                <div class="action-buttons">
                <!-- Edit Button: Typically a GET request to a separate edit page -->
                <form action="/edit/<%= d.id %>" method="GET" style="display:inline;">
                    <button type="submit" class="btn-edit">Edit</button>
                </form>

                <!-- Delete Button: Typically a POST request (often overridden to DELETE) -->
                <form action="/delete/<%= d.id %>" method="POST" style="display:inline;">
                    <button type="submit" class="btn-delete" onclick=" return confirm('Are you sure?')">Delete</button>
                </form>
                </div>



            </div>
        <% }) %>
    </div>

</body>
</html>