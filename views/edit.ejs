<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Book Rating</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="/style.css">
    </head>
    <body>

        <main class="form-page">
            <div class="form-wrapper">

        <% if(locals.editingData) { %>

            <div class="book-detail">
                <img src="<%= editingData.cover_url %>" alt="<%= editingData.title %> cover">
                <h1><%= editingData.title %></h1>
                <h2>Author: <%= editingData.author %></h2>
            </div>

            <div class="form-card">
                <div class="form-card__header">
                    <h1>Edit review</h1>
                    <p>Update your rating and thoughts on this book.</p>
                </div>

                <form action="/edit/<%= editingData.id %>/post" method="POST">
                    <div class="form-group">
                        <label class="form-label" for="stars">Rating</label>
                        <div class="star-rating" role="radiogroup" aria-label="Rating out of 5">
                            <input type="radio" id="edit-star5" name="stars" value="5" <%= Number(editingData.stars) === 5 ? 'checked' : '' %>><label for="edit-star5" title="5 stars">&#9733;</label>
                            <input type="radio" id="edit-star4" name="stars" value="4" <%= Number(editingData.stars) === 4 ? 'checked' : '' %>><label for="edit-star4" title="4 stars">&#9733;</label>
                            <input type="radio" id="edit-star3" name="stars" value="3" <%= Number(editingData.stars) === 3 ? 'checked' : '' %>><label for="edit-star3" title="3 stars">&#9733;</label>
                            <input type="radio" id="edit-star2" name="stars" value="2" <%= Number(editingData.stars) === 2 ? 'checked' : '' %>><label for="edit-star2" title="2 stars">&#9733;</label>
                            <input type="radio" id="edit-star1" name="stars" value="1" <%= Number(editingData.stars) === 1 ? 'checked' : '' %>><label for="edit-star1" title="1 star">&#9733;</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="review">Review</label>
                        <textarea class="form-textarea" id="review" name="review" placeholder="Share your thoughts..."><%= editingData.review %></textarea>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Confirm</button>
                        <a href="/" class="btn btn-ghost">Cancel</a>
                    </div>
                </form>
            </div>

        <% } else { %>

            <div class="form-card">
                <div class="form-card__header">
                    <h1>Create review</h1>
                    <p>Add a new book to your library and rate it.</p>
                </div>

                <form action="/new/post" method="POST">

                    <div class="form-group">
                        <label class="form-label" for="title-input">Title</label>
                        <div class="input-row">
                            <input
                                type="text"
                                class="form-input"
                                id="title-input"
                                name="title"
                                placeholder="Insert book title..."
                            >
                            <button type="button" class="btn btn-secondary" id="find-image-btn">
                                Find Image
                            </button>
                        </div>
                    </div>

                    <div id="image-preview-container" class="image-preview">

                        <div
                            id="image-loading"
                            style="
                                display:none;
                                width:200px;
                                height:300px;
                                background:#efefef;
                                border:1px solid #ccc;
                                align-items:center;
                                justify-content:center;
                                font-size:18px;
                                color:#666;
                            ">
                            Loading...
                        </div>

                        <img
                            id="book-cover-img"
                            src=""
                            alt="Book Cover Preview"
                            style="display:none; max-width:200px;"
                        >
                    </div>

                    <input
                        id="book-cover-img-value"
                        name="cover_url"
                        type="hidden"
                    >

                    <div class="form-group">
                        <label class="form-label" for="author-name">Author</label>
                        <input
                            type="text"
                            class="form-input"
                            id="author-name"
                            name="author"
                            placeholder="Type an author or click Find Image"
                        >
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="stars">Rating</label>
                        <div class="star-rating" role="radiogroup" aria-label="Rating out of 5">
                            <input type="radio" id="star5" name="stars" value="5"><label for="star5" title="5 stars">&#9733;</label>
                            <input type="radio" id="star4" name="stars" value="4"><label for="star4" title="4 stars">&#9733;</label>
                            <input type="radio" id="star3" name="stars" value="3" checked><label for="star3" title="3 stars">&#9733;</label>
                            <input type="radio" id="star2" name="stars" value="2"><label for="star2" title="2 stars">&#9733;</label>
                            <input type="radio" id="star1" name="stars" value="1"><label for="star1" title="1 star">&#9733;</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="review">Review</label>
                        <textarea
                            class="form-textarea"
                            id="review"
                            name="review"
                            placeholder="Insert book review..."
                        ></textarea>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Create</button>
                        <a href="/" class="btn btn-ghost">Cancel</a>
                    </div>

                </form>
            </div>

        <% } %>

            </div>
        </main>

        <script>
            const findImageBtn = document.getElementById("find-image-btn");
            const titleInput = document.getElementById("title-input");

            const imageLoading = document.getElementById("image-loading");
            const bookCoverImg = document.getElementById("book-cover-img");
            const bookCoverImgValue = document.getElementById("book-cover-img-value");

            const authorNameText = document.getElementById("author-name");

            function toTitleCase(str) {
                if (!str) return "";

                return str
                    .toLowerCase()
                    .split(" ")
                    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
                    .join(" ");
            }

            findImageBtn.addEventListener("click", async (e) => {
                e.preventDefault();

                const title = titleInput.value.trim();

                if (!title) {
                    alert("Please enter a title first!");
                    return;
                }

                // Reset previous results
                bookCoverImg.style.display = "none";
                bookCoverImg.src = "";
                bookCoverImgValue.value = "";

                authorNameText.value = "";
                authorNameText.placeholder = "Loading author...";
                authorNameText.disabled = true;

                // Show loading placeholder
                imageLoading.style.display = "flex";

                // Disable button
                findImageBtn.disabled = true;
                findImageBtn.classList.add("is-loading");
                findImageBtn.innerText = "Searching...";

                try {

                    // Fetch image and author simultaneously
                    const [imageResponse, authorResponse] = await Promise.all([
                        fetch(`/new/api/cover?title=${encodeURIComponent(title)}`),
                        fetch(`/new/api/author?title=${encodeURIComponent(title)}`)
                    ]);

                    if (!imageResponse.ok) {
                        throw new Error("Image request failed.");
                    }

                    if (!authorResponse.ok) {
                        throw new Error("Author request failed.");
                    }

                    const imageData = await imageResponse.json();
                    const authorData = await authorResponse.json();

                    // Hide loading placeholder
                    imageLoading.style.display = "none";

                    // Show image
                    if (imageData.coverUrl) {
                        bookCoverImg.src = imageData.coverUrl;
                        bookCoverImg.style.display = "block";
                        bookCoverImgValue.value = imageData.coverUrl;
                    } else {
                        alert("No image found for this title.");
                    }

                    // Fill author
                    if (authorData.authorName) {
                        authorNameText.value = authorData.authorName;
                    } else {
                        authorNameText.placeholder = "Author not found";
                    }

                } catch (error) {

                    console.error(error);

                    imageLoading.style.display = "none";

                    alert("An error occurred while retrieving book information.");

                    authorNameText.placeholder = "Unable to retrieve author";

                } finally {

                    authorNameText.disabled = false;

                    findImageBtn.disabled = false;
                    findImageBtn.classList.remove("is-loading");
                    findImageBtn.innerText = "Find Image";

                    titleInput.value = toTitleCase(title);

                    
                }
            });
        </script>

    </body>
</html>
